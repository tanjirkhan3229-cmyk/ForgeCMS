# OpenRouter credentials for the AI writer (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Any OpenRouter model id; reasoning models recommended
OPENROUTER_MODEL=openai/gpt-5.4
# Database — omit to use local SQLite (backend/forge.db).
# For Supabase use the session pooler (IPv4) and URL-encode the password:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Comma-separated origins allowed to call the API from a browser
# CORS_ORIGINS=http://localhost:5173,https://www.forgesop.com,https://forgesop.com
